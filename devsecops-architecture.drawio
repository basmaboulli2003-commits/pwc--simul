<mxfile host="app.diagrams.net">
  <diagram name="DevSecOps Architecture">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- LAYER 0 -->
        <mxCell id="dev" value="Git Repos (Frontend + Microservices)" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="260" height="60" as="geometry"/>
        </mxCell>

        <!-- CI/CD -->
        <mxCell id="jenkins" value="Jenkins CI/CD Pipeline" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="360" y="40" width="260" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="harbor" value="Harbor Registry + Cosign + ClamAV" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="700" y="40" width="300" height="60" as="geometry"/>
        </mxCell>

        <!-- K8s -->
        <mxCell id="k8s" value="Kubernetes Cluster (KIND)" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="40" y="160" width="960" height="200" as="geometry"/>
        </mxCell>

        <!-- Istio -->
        <mxCell id="istio" value="Istio Service Mesh (Ingress + mTLS + JWT + Rate Limit)" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="80" y="200" width="400" height="120" as="geometry"/>
        </mxCell>

        <!-- Microservices -->
        <mxCell id="ms" value="Microservices (Identity / Order / Payment / Product / Email)" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="520" y="200" width="450" height="120" as="geometry"/>
        </mxCell>

        <!-- Kafka -->
        <mxCell id="kafka" value="Kafka Event Bus (Encrypted AES-256)" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="520" y="340" width="450" height="60" as="geometry"/>
        </mxCell>

        <!-- Vault -->
        <mxCell id="vault" value="HashiCorp Vault + External Secrets Operator" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="40" y="400" width="450" height="80" as="geometry"/>
        </mxCell>

        <!-- Observability -->
        <mxCell id="obs" value="Observability (Prometheus + Jaeger + Kiali)" style="rounded=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="520" y="420" width="450" height="80" as="geometry"/>
        </mxCell>

        <!-- EDGES -->
        <mxCell id="e1" edge="1" parent="1" source="dev" target="jenkins" style="endArrow=block;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e2" edge="1" parent="1" source="jenkins" target="harbor" style="endArrow=block;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e3" edge="1" parent="1" source="harbor" target="k8s" style="endArrow=block;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e4" edge="1" parent="1" source="k8s" target="istio" style="endArrow=block;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e5" edge="1" parent="1" source="istio" target="ms" style="endArrow=block;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e6" edge="1" parent="1" source="ms" target="kafka" style="endArrow=block;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e7" edge="1" parent="1" source="vault" target="k8s" style="dashed=1;endArrow=block;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e8" edge="1" parent="1" source="ms" target="obs" style="dashed=1;endArrow=block;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>